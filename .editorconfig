; https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = crlf
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,rst}]
trim_trailing_whitespace = false

[*.{toml,yaml,yml}]
indent_style = space
indent_size = 2
